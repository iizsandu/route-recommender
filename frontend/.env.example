# Backend API base URL (no trailing slash)
# Set this in the Vercel dashboard: Project Settings > Environment Variables
# Scope: Production = Azure Container Apps URL, Preview = same or a staging URL
# WHY: Vite only exposes VITE_* vars to the browser bundle — other vars are stripped at build time
VITE_API_BASE_URL=https://your-app.azurecontainerapps.io

# MapTiler map tiles — public key, domain-restricted in MapTiler dashboard (not secret)
VITE_MAPTILER_KEY=your_key_here
