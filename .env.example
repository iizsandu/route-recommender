# Cosmos DB (read-only) — get from Azure Portal > Cosmos DB > Keys
COSMOS_CONNECTION_STRING=AccountEndpoint=https://YOURACCOUNT.documents.azure.com:443/;AccountKey=YOURKEY==;
COSMOS_DATABASE_NAME=route_recommender
COSMOS_CONTAINER_NAME=structured_crimes

# Geocoding — Mappls (MapMyIndia) primary, Nominatim fallback
# Get key from https://developer.mappls.com → Dashboard → REST API
# Free tier: 250 requests/day. Leave empty to skip Mappls and use Nominatim only.
MAPPLS_API_KEY=

# MapTiler — https://cloud.maptiler.com/account/keys
# WHY: public key — MapTiler enforces domain restriction, not secrecy
VITE_MAPTILER_KEY=your_key_here

# Risk model — path to artifacts directory produced by ml/train_kde.py
# Run `python -m ml.train_kde ml/data/snapshots/crimes_YYYY-MM-DD.parquet` to generate
KDE_ARTIFACTS_DIR=ml/artifacts

# Banding thresholds — p33/p66 of real ROUTE total_scores (route_eta_sec ×
# mean per-waypoint score), so they live on the ~10^4 accumulated scale.
# Recalibrate after each retrain: python -m ml.calibrate_bands
BAND_LOW_THRESHOLD=35671.76
BAND_HIGH_THRESHOLD=58229.06

# MLflow — backend reads registry to hot-reload Production model hourly
# WHY sqlite for local dev: works on a single machine; for Azure Container Apps
# this must point to a shared remote server (tech debt #7)
MLFLOW_TRACKING_URI=sqlite:///ml/artifacts/mlruns.db
MLFLOW_REGISTRY_URI=sqlite:///ml/artifacts/mlruns.db

# How often (seconds) the backend checks the MLflow registry for a new model
# Default 3600 (hourly). Set lower in dev to test hot-reload quickly.
MODEL_RELOAD_INTERVAL_SECONDS=3600

# CORS — comma-separated, no trailing slash
ALLOWED_ORIGINS=http://localhost:3000,https://route-recommender.vercel.app

# Logging
LOG_LEVEL=INFO
# WHY: use "console" locally for readability; "json" in Azure for structured log ingestion
LOG_FORMAT=console

# Heatmap (Phase 5 — pre-computed risk surface)
# Generated by `python -m ml.generate_heatmap` after each retrain.
HEATMAP_PATH=ml/artifacts/heatmap.geojson

# Sentry (Phase 5 — frontend error tracking)
# Get DSN from https://sentry.io → your project → Settings → Client Keys
# Leave empty for local dev — Sentry init is skipped when DSN is absent
VITE_SENTRY_DSN=

# LightGBM ensemble (Phase 4)
# WHY False default: safe rollback — flip to True only after train_lightgbm.py has run
# and lgb_*.pkl artifacts exist in LGB_ARTIFACTS_DIR.
USE_LIGHTGBM=False
LGB_ARTIFACTS_DIR=ml/artifacts
KDE_ENSEMBLE_WEIGHT=0.7
LGB_ENSEMBLE_WEIGHT=0.3

# Retrieval (Qdrant hybrid search) — local only
# Leave QDRANT_HOST empty to disable retrieval features gracefully.
# To enable locally:
#   1. docker compose up qdrant
#   2. pip install -r retrieval/requirements.txt
#   3. python scripts/build_index.py --rebuild
#   4. Set QDRANT_HOST=localhost below
QDRANT_HOST=
QDRANT_PORT=6333
# Qdrant Cloud (production) — takes precedence over QDRANT_HOST when set.
# WHY cloud: Azure Container Apps has no persistent disk; local Qdrant loses the
# index on every cold start. Cloud free tier (1 GB, no expiry) solves this.
# Get URL + key from cloud.qdrant.io → your cluster → "Connect".
QDRANT_URL=
QDRANT_API_KEY=
BM25_MODEL_PATH=retrieval/bm25_model.pkl

# ── Voice AI Agent ──────────────────────────────────────────────────────────
# Floating mic button on the map — records audio, transcribes locally via
# faster-whisper, then queries a CrewAI agent backed by either Ollama (local)
# or Anthropic Claude (cloud). Set LLM_PROVIDER to switch between them.

# "ollama" uses a locally running Ollama server (free, private).
# "anthropic" uses the Anthropic API (requires ANTHROPIC_API_KEY below).
LLM_PROVIDER=ollama

# Base URL for the Ollama server.
# WHY host.docker.internal: inside Docker containers, the Windows host is
# reachable at this hostname. Use http://localhost:11434 for non-Docker dev.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama model name. gemma4:e4b is 9.6 GB — pull once with `ollama pull gemma4:e4b`.
OLLAMA_MODEL=gemma4:e4b

# Only required when LLM_PROVIDER=anthropic.
# Get key from https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=

# Model ID used when LLM_PROVIDER=anthropic.
AGENT_MODEL=claude-sonnet-4-6

# Whisper model size: "tiny" (39 MB) | "base" (74 MB) | "small" (244 MB).
# "base" is a good default — fast enough on CPU, accurate enough for clear speech.
# Pre-downloaded into the Docker image at build time so there is no cold-start delay.
WHISPER_MODEL_SIZE=base

# Whisper inference device: "cpu" or "cuda".
# "cuda" requires an NVIDIA GPU with CUDA drivers inside the container.
# WHY default cpu: works everywhere; switch to cuda if you have an NVIDIA GPU
# (reduces transcription time from ~3s to ~0.3s for a 10-second clip).
WHISPER_DEVICE=cpu
